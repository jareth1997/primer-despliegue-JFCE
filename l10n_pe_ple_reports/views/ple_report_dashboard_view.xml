    <record id="l10n_pe_ple_report_type_tree_view" model="ir.ui.view">
        <field name="name">l10n_pe.ple.report.type.tree</field>
        <field name="model">l10n_pe.ple.report.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="system_type"/>
                <field name="code_ids" widget="many2many_tags"/>
                <field name="allowed_document_type_ids" widget="many2many_tags" optional="hide"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="l10n_pe_ple_report_type_form_view" model="ir.ui.view">
        <field name="name">SIRE/PLE report type</field>
        <field name="model">l10n_pe.ple.report.type</field>
        <field name="arch" type="xml">
            <form string="SIRE/PLE report type">
                <header/>
                <sheet>
                    <div class="oe_title" name="title">
                        <field name="display_name" invisible="1"/>
                        <h1>
                            <field name="name" nolabel="1" force_save="1" invisible="name == '/'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="opportunity_eeff_code"/>
                            <field name="category_id"/>
                            <field name="system_type"/>
                            <field name="company_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="color" invisible="1"/>
                            <field name="show_on_dashboard"/>
                        </group>
                    </group>
                    <notebook>
                        <page id="code_tab" string="Book codes">
                            <field name="code_ids">
                                <list string="Book codes" editable="bottom" create="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="color" widget="color_picker"/>
                                </list>
                            </field>
                        </page>
                        <page id="document_type_tab" string="Document Types">
                            <field name="allowed_document_type_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
