    <record id="open_ple_report_type_dashboard_kanban_ple_contables" model="ir.actions.act_window">
        <field name="name">PLE - Libros Contables</field>
        <field name="res_model">l10n_pe.ple.report.type</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_id" ref="l10n_pe_ple_report_type_dashboard_kanban_view"/>
        <field name="search_view_id" ref="l10n_pe_ple_report_type_search_view"/>
        <field name="usage">menu</field>
        <field name="context">{'search_default_dashboard':1}</field>
