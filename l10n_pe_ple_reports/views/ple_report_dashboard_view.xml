<odoo>
    <record id="l10n_pe_ple_report_type_dashboard_kanban_view" model="ir.ui.view">
        <field name="name">l10n_pe.ple.report.type.dashboard.kanban</field>
        <field name="model">l10n_pe.ple.report.type</field>
        <field name="arch" type="xml">
            <kanban create="false" class="oe_background_grey o_kanban_dashboard o_account_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="opportunity_eeff_code"/>
                <field name="color"/>
                <field name="category_id"/>
                <field name="system_type"/>
                <field name="show_on_dashboard"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_color_#{record.color.raw_value} oe_kanban_card">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary d-flex align-items-center justify-content-between">
                                        <a name="action_view_reports" type="object" class="flex-grow-1">
                                            <span><field name="name" class="o_primary"/></span>
                                        </a>
                                        <div class="o_dropdown_kanban dropdown ms-2">
                                            <a class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" href="#" role="button" aria-label="Dropdown menu" title="Dropdown menu">
                                                <span class="fa fa-ellipsis-v"/>
                                            </a>
                                            <div class="dropdown-menu" role="menu">
                                                <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                                <a role="menuitem" type="object" name="action_view_reports" class="dropdown-item">Reports</a>
                                                <div role="separator" class="dropdown-divider"/>
                                                <ul class="oe_kanban_colorpicker" data-field="color"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div t-if="record.code_ids.raw_value.length > 0" class="mt-2">
                                        <field name="code_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content mt0">
                                <div class="row mb16">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_reports" type="object">View reports</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="l10n_pe_ple_report_type_search_view" model="ir.ui.view">
        <field name="name">l10n_pe.ple.report.type.search</field>
        <field name="model">l10n_pe.ple.report.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <filter name="dashboard" string="On Dashboard" domain="[('show_on_dashboard', '=', True)]"/>
                <group>
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_by_system_type" string="System Type" context="{'group_by': 'system_type'}"/>
                </group>
                <searchpanel>
                    <field name="category_id" icon="fa-tag" color="color" enable_counters="1"/>
                    <field name="system_type" icon="fa-filter" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="open_ple_report_type_dashboard_kanban" model="ir.actions.act_window">
        <field name="name">SIRE/PLE Report types</field>
        <field name="res_model">l10n_pe.ple.report.type</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_id" ref="l10n_pe_ple_report_type_dashboard_kanban_view"/>
        <field name="search_view_id" ref="l10n_pe_ple_report_type_search_view"/>
        <field name="usage">menu</field>
        <field name="context">{'search_default_dashboard':1}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_neutral_face">You need to install an extra module to see the PLE reports</p>
        </field>
    </record>

    <record id="open_ple_report_type_dashboard_kanban_ple" model="ir.actions.act_window">
        <field name="name">PLE Report types</field>
        <field name="res_model">l10n_pe.ple.report.type</field>
        <field name="view_mode">kanban,form</field>
        <field name="view_id" ref="l10n_pe_ple_report_type_dashboard_kanban_view"/>
        <field name="search_view_id" ref="l10n_pe_ple_report_type_search_view"/>
        <field name="usage">menu</field>
        <field name="context">{'search_default_dashboard':1}</field>
        <field name="domain">[('system_type', '=', 'ple')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_neutral_face">You need to install an extra module to see the PLE reports</p>
        </field>
    </record>

